import { ScrollView, Text, View, TouchableOpacity } from 'react-native';
import { useState } from 'react';
import { ScreenContainer } from '@/components/screen-container';

interface Indicator {
  id: string;
  name: string;
  value: number;
  status: string;
  description: string;
  range: [number, number];
}

export default function IndicatorsScreen() {
  const [selectedIndicator, setSelectedIndicator] = useState<string | null>(null);

  const indicators: Indicator[] = [
    {
      id: 'rsi',
      name: 'RSI (Relative Strength Index)',
      value: 65.2,
      status: 'Strong Bullish',
      description: 'Measures momentum and overbought/oversold conditions',
      range: [0, 100],
    },
    {
      id: 'macd',
      name: 'MACD (Moving Average Convergence Divergence)',
      value: 0.45,
      status: 'Bullish Signal',
      description: 'Identifies trend changes and momentum shifts',
      range: [-1, 1],
    },
    {
      id: 'bb',
      name: 'Bollinger Bands',
      value: 50,
      status: 'Mid-Band',
      description: 'Identifies volatility and support/resistance levels',
      range: [0, 100],
    },
    {
      id: 'adx',
      name: 'ADX (Average Directional Index)',
      value: 35.8,
      status: 'Strong Trend',
      description: 'Measures trend strength without direction',
      range: [0, 100],
    },
    {
      id: 'atr',
      name: 'ATR (Average True Range)',
      value: 2.45,
      status: 'Moderate',
      description: 'Measures market volatility',
      range: [0, 10],
    },
    {
      id: 'stoch',
      name: 'Stochastic Oscillator',
      value: 72.5,
      status: 'Overbought',
      description: 'Compares closing price to price range',
      range: [0, 100],
    },
  ];

  const getStatusColor = (status: string) => {
    if (status.includes('Bullish') || status.includes('Strong')) return 'text-success';
    if (status.includes('Bearish')) return 'text-error';
    return 'text-warning';
  };

  const getProgressColor = (value: number, range: [number, number]) => {
    const percentage = ((value - range[0]) / (range[1] - range[0])) * 100;
    if (percentage > 70) return 'bg-success';
    if (percentage < 30) return 'bg-error';
    return 'bg-warning';
  };

  return (
    <ScreenContainer className="p-4">
      <ScrollView contentContainerStyle={{ flexGrow: 1 }}>
        <View className="gap-4">
          {/* Header */}
          <View className="mb-2">
            <Text className="text-3xl font-bold text-foreground">Technical Indicators</Text>
            <Text className="text-sm text-muted mt-1">Real-time indicator analysis</Text>
          </View>

          {/* MPS Indicator Summary */}
          <View className="bg-primary/10 rounded-xl p-4 border border-primary/20">
            <Text className="text-base font-semibold text-primary mb-2">Manus Pro Signal (MPS)</Text>
            <View className="gap-2">
              <View className="flex-row justify-between">
                <Text className="text-sm text-foreground">Signal Strength</Text>
                <Text className="text-sm font-bold text-primary">82-87%</Text>
              </View>
              <View className="flex-row justify-between">
                <Text className="text-sm text-foreground">Components</Text>
                <Text className="text-sm font-bold text-primary">4 Weighted</Text>
              </View>
              <View className="flex-row justify-between">
                <Text className="text-sm text-foreground">Timeframes</Text>
                <Text className="text-sm font-bold text-primary">Multi-TF</Text>
              </View>
            </View>
          </View>

          {/* Individual Indicators */}
          <View className="gap-3">
            <Text className="text-lg font-semibold text-foreground">Indicators</Text>

            {indicators.map((indicator) => (
              <TouchableOpacity
                key={indicator.id}
                onPress={() =>
                  setSelectedIndicator(selectedIndicator === indicator.id ? null : indicator.id)
                }
                activeOpacity={0.7}
              >
                <View className="bg-surface rounded-xl p-4 border border-border">
                  {/* Header */}
                  <View className="flex-row justify-between items-start mb-3">
                    <View className="flex-1">
                      <Text className="text-base font-semibold text-foreground">{indicator.name}</Text>
                      <Text className={`text-xs font-semibold mt-1 ${getStatusColor(indicator.status)}`}>
                        {indicator.status}
                      </Text>
                    </View>
                    <Text className="text-lg font-bold text-primary">{indicator.value.toFixed(1)}</Text>
                  </View>

                  {/* Progress Bar */}
                  <View className="mb-3">
                    <View className="bg-background rounded-full h-2 overflow-hidden">
                      <View
                        className={`${getProgressColor(indicator.value, indicator.range)} h-full`}
                        style={{
                          width: `${
                            ((indicator.value - indicator.range[0]) /
                              (indicator.range[1] - indicator.range[0])) *
                            100
                          }%`,
                        }}
                      />
                    </View>
                    <View className="flex-row justify-between mt-1">
                      <Text className="text-xs text-muted">{indicator.range[0]}</Text>
                      <Text className="text-xs text-muted">{indicator.range[1]}</Text>
                    </View>
                  </View>

                  {/* Description (Expanded) */}
                  {selectedIndicator === indicator.id && (
                    <View className="bg-background rounded-lg p-3 mt-3 border border-border/50">
                      <Text className="text-sm text-muted leading-relaxed">
                        {indicator.description}
                      </Text>
                    </View>
                  )}
                </View>
              </TouchableOpacity>
            ))}
          </View>

          {/* Indicator Legend */}
          <View className="bg-surface rounded-xl p-4 border border-border">
            <Text className="text-base font-semibold text-foreground mb-3">Legend</Text>
            <View className="gap-2">
              <View className="flex-row items-center gap-2">
                <View className="w-3 h-3 rounded-full bg-success" />
                <Text className="text-sm text-foreground">Bullish / Strong</Text>
              </View>
              <View className="flex-row items-center gap-2">
                <View className="w-3 h-3 rounded-full bg-warning" />
                <Text className="text-sm text-foreground">Neutral / Moderate</Text>
              </View>
              <View className="flex-row items-center gap-2">
                <View className="w-3 h-3 rounded-full bg-error" />
                <Text className="text-sm text-foreground">Bearish / Weak</Text>
              </View>
            </View>
          </View>

          {/* Help Section */}
          <View className="bg-surface rounded-xl p-4 border border-border">
            <Text className="text-base font-semibold text-foreground mb-2">How to Use</Text>
            <Text className="text-sm text-muted leading-relaxed">
              Tap any indicator to see detailed information. The MPS indicator combines all these
              signals into one powerful buy/sell recommendation with 82-87% accuracy.
            </Text>
          </View>

          <View className="h-4" />
        </View>
      </ScrollView>
    </ScreenContainer>
  );
}
