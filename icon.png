import { ScrollView, Text, View, TouchableOpacity, Switch } from 'react-native';
import { useState } from 'react';
import { ScreenContainer } from '@/components/screen-container';
import { useColorScheme } from '@/hooks/use-color-scheme';

export default function SettingsScreen() {
  const colorScheme = useColorScheme();
  const [theme, setTheme] = useState<'light' | 'dark' | 'system'>(colorScheme === 'dark' ? 'dark' : 'light');
  const [notificationsEnabled, setNotificationsEnabled] = useState(true);
  const [soundEnabled, setSoundEnabled] = useState(true);
  const [vibrationEnabled, setVibrationEnabled] = useState(true);

  const SettingRow = ({
    label,
    description,
    value,
    onToggle,
  }: {
    label: string;
    description?: string;
    value: boolean;
    onToggle: (val: boolean) => void;
  }) => (
    <View className="flex-row justify-between items-center py-4 px-4 border-b border-border">
      <View className="flex-1">
        <Text className="text-base font-semibold text-foreground">{label}</Text>
        {description && <Text className="text-xs text-muted mt-1">{description}</Text>}
      </View>
      <Switch value={value} onValueChange={onToggle} />
    </View>
  );

  return (
    <ScreenContainer className="p-0">
      <ScrollView contentContainerStyle={{ flexGrow: 1 }}>
        <View className="gap-6 pb-6">
          {/* Header */}
          <View className="px-4 pt-4 pb-2">
            <Text className="text-3xl font-bold text-foreground">Settings</Text>
            <Text className="text-sm text-muted mt-1">Customize your trading experience</Text>
          </View>

          {/* Theme Section */}
          <View className="bg-surface border border-border rounded-xl mx-4 overflow-hidden">
            <View className="px-4 py-3 border-b border-border bg-background/50">
              <Text className="text-lg font-semibold text-foreground">Appearance</Text>
            </View>

            <View className="flex-row justify-between items-center py-4 px-4 border-b border-border">
              <Text className="text-base font-semibold text-foreground">Theme</Text>
              <View className="flex-row gap-2">
                {(['light', 'dark', 'system'] as const).map((t) => (
                  <TouchableOpacity
                    key={t}
                    onPress={() => setTheme(t)}
                    className={`px-3 py-1 rounded ${
                      theme === t ? 'bg-primary' : 'bg-background border border-border'
                    }`}
                  >
                    <Text className={`text-xs font-semibold capitalize ${theme === t ? 'text-background' : 'text-foreground'}`}>
                      {t}
                    </Text>
                  </TouchableOpacity>
                ))}
              </View>
            </View>
          </View>

          {/* Notifications Section */}
          <View className="bg-surface border border-border rounded-xl mx-4 overflow-hidden">
            <View className="px-4 py-3 border-b border-border bg-background/50">
              <Text className="text-lg font-semibold text-foreground">Notifications</Text>
            </View>

            <SettingRow
              label="Enable Notifications"
              description="Receive trading alerts and updates"
              value={notificationsEnabled}
              onToggle={setNotificationsEnabled}
            />

            <SettingRow
              label="Sound"
              description="Play sound for alerts"
              value={soundEnabled}
              onToggle={setSoundEnabled}
            />

            <View className="flex-row justify-between items-center py-4 px-4">
              <View className="flex-1">
                <Text className="text-base font-semibold text-foreground">Vibration</Text>
                <Text className="text-xs text-muted mt-1">Haptic feedback for interactions</Text>
              </View>
              <Switch value={vibrationEnabled} onValueChange={setVibrationEnabled} />
            </View>
          </View>

          {/* Indicator Settings Section */}
          <View className="bg-surface border border-border rounded-xl mx-4 overflow-hidden">
            <View className="px-4 py-3 border-b border-border bg-background/50">
              <Text className="text-lg font-semibold text-foreground">MPS Indicator</Text>
            </View>

            <View className="flex-row justify-between items-center py-4 px-4 border-b border-border">
              <View className="flex-1">
                <Text className="text-base font-semibold text-foreground">Sensitivity</Text>
                <Text className="text-xs text-muted mt-1">Adjust signal generation threshold</Text>
              </View>
            </View>

            <View className="flex-row justify-between gap-2 px-4 py-4">
              {(['Conservative', 'Moderate', 'Aggressive'] as const).map((level) => (
                <TouchableOpacity
                  key={level}
                  className="flex-1 py-2 px-3 rounded bg-background border border-border items-center"
                >
                  <Text className="text-xs font-semibold text-foreground">{level}</Text>
                </TouchableOpacity>
              ))}
            </View>
          </View>

          {/* Data Settings Section */}
          <View className="bg-surface border border-border rounded-xl mx-4 overflow-hidden">
            <View className="px-4 py-3 border-b border-border bg-background/50">
              <Text className="text-lg font-semibold text-foreground">Data</Text>
            </View>

            <View className="flex-row justify-between items-center py-4 px-4 border-b border-border">
              <View className="flex-1">
                <Text className="text-base font-semibold text-foreground">Update Frequency</Text>
                <Text className="text-xs text-muted mt-1">Real-time data refresh rate</Text>
              </View>
            </View>

            <View className="flex-row justify-between gap-2 px-4 py-4">
              {(['1s', '5s', '10s'] as const).map((freq) => (
                <TouchableOpacity
                  key={freq}
                  className="flex-1 py-2 px-3 rounded bg-background border border-border items-center"
                >
                  <Text className="text-xs font-semibold text-foreground">{freq}</Text>
                </TouchableOpacity>
              ))}
            </View>
          </View>

          {/* About Section */}
          <View className="bg-surface border border-border rounded-xl mx-4 overflow-hidden">
            <View className="px-4 py-3 border-b border-border bg-background/50">
              <Text className="text-lg font-semibold text-foreground">About</Text>
            </View>

            <View className="px-4 py-4 border-b border-border">
              <Text className="text-sm text-foreground font-semibold">Banksy</Text>
              <Text className="text-xs text-muted mt-1">Professional Trading Analysis</Text>
              <Text className="text-xs text-muted mt-2">Version 1.0.0</Text>
            </View>

            <TouchableOpacity className="px-4 py-4 border-b border-border">
              <Text className="text-sm font-semibold text-primary">Privacy Policy</Text>
            </TouchableOpacity>

            <TouchableOpacity className="px-4 py-4 border-b border-border">
              <Text className="text-sm font-semibold text-primary">Terms of Service</Text>
            </TouchableOpacity>

            <TouchableOpacity className="px-4 py-4">
              <Text className="text-sm font-semibold text-primary">Contact Support</Text>
            </TouchableOpacity>
          </View>

          <View className="h-4" />
        </View>
      </ScrollView>
    </ScreenContainer>
  );
}
